{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "moralcraftsmanship.eu" }],
      "destination": "https://moreelvakmanschap.nl/welcome?lang=en",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.moralcraftsmanship.eu" }],
      "destination": "https://moreelvakmanschap.nl/welcome?lang=en",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/wisselwerking",
      "destination": "/wisselwerking/index.html"
    },
    {
      "source": "/wisselwerking/((?!assets/).*)",
      "destination": "/wisselwerking/index.html"
    },
    {
      "source": "/((?!api/|downloads/|images/|wisselwerking).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/wisselwerking/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/wisselwerking/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
