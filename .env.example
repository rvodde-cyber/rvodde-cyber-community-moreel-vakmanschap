# Optioneel: embed-URL van Google Form (viewform?embedded=true)
# Zonder deze variabele opent het aanmeldformulier een mail naar lectoraatethischwerken@fontys.nl
VITE_GOOGLE_FORM_URL=

# ── Workshop Hub ──────────────────────────────────────────────
# Kill-switch: alleen "true" schakelt de hub in. Default/afwezig = uit.
WORKSHOP_HUB_ENABLED=false
# Client-spiegel (Vite build-time). Zelfde waarde als WORKSHOP_HUB_ENABLED aanhouden.
VITE_WORKSHOP_HUB_ENABLED=false

# Secrets — ALLEEN in Vercel Environment Variables (nooit in de repo committen)
WORKSHOP_SESSION_SECRET=
WORKSHOP_PASSWORD=
WORKSHOP_VOORPROEF_PASSWORD=
